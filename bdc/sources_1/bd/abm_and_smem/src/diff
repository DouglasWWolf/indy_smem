tb_root=~/fpga

update=0 
if [ "$1" == "-update" ]; then
    update=1
    shift
fi 

comp()
{
    local_path=$1
    tb_folder=$2
    tb_path=$tb_folder/$(basename $local_path)

    if [ ! -f $local_path ]; then
        echo "NOT FOUND: $local_path"
        return
    fi

    if [ ! -f $tb_path ]; then
        echo "NOT FOUND: $tb_path"
        return
    fi

    diff $local_path $tb_path >/dev/null

    if [ $? -ne 0 ]; then
        echo "$local_path <> $tb_path"
        if [ $update -eq 1 ]; then
            echo -n "Copy it? (y/n) " 
            read answer
            if [ $answer == "y" ] || [ $answer == "Y" ]; then
                cp $tb_path $local_path
            fi
        fi 
    fi
}


